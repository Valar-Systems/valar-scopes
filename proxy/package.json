{
  "name": "blipscope-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker edge proxy for Blipscope devices: /v1/blips, /v1/enrich, /v1/config",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy:staging": "wrangler deploy --env staging",
    "tail:staging": "wrangler tail --env staging"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20250906.0",
    "typescript": "^5.5.0",
    "vitest": "~3.2.0",
    "wrangler": "4.35.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.4": true,
    "workerd@1.20250906.0": true
  }
}
